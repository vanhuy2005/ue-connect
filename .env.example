APP_NAME=UEConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ue-connect.test

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# ==========================================
# 1. GIAI ĐOẠN NỀN TẢNG (SAFE FOUNDATION MODE)
# ==========================================
# Mặc định sử dụng SQLite để ứng dụng boot an toàn mà không bị crash khi chưa cài driver SQL Server.
# Hãy chắc chắn chạy lệnh: type nul > database\database.sqlite trước khi chạy artisan.
DB_CONNECTION=sqlite

# Đưa các driver hệ thống về cấu hình an toàn (không ghi nhận vào database)
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Tắt kết nối WebSocket bằng cách xuất log
BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

# === Media Storage Strategy ===
MEDIA_STORAGE_STRATEGY=hybrid_public_cloudinary
# Supported: local_only, r2_primary, hybrid_public_cloudinary
MEDIA_DISK=r2_public
PRIVATE_MEDIA_DISK=r2_private

MEDIA_R2_ENABLED=true
MEDIA_CLOUDINARY_ENABLED=true
MEDIA_FIREBASE_ENABLED=false

MEDIA_MAX_AVATAR_MB=5
MEDIA_MAX_COVER_MB=8
MEDIA_MAX_POST_IMAGE_MB=10
MEDIA_MAX_MESSAGE_IMAGE_MB=10
MEDIA_POST_MAX_IMAGES=4
MEDIA_USER_DAILY_UPLOAD_COUNT=100
MEDIA_USER_DAILY_UPLOAD_MB=100
MEDIA_USER_MONTHLY_UPLOAD_MB=1000
MEDIA_GLOBAL_DAILY_UPLOAD_MB=5000
MEDIA_CLOUDINARY_DAILY_SYNC_LIMIT=1000
MEDIA_DISABLE_CLOUDINARY_WHEN_LIMIT_REACHED=true

MEDIA_TEMP_TTL_MINUTES=60
MEDIA_IMAGE_OUTPUT_FORMAT=webp
MEDIA_IMAGE_QUALITY=82
MEDIA_STRIP_EXIF=true
MEDIA_KEEP_ORIGINAL_PUBLIC=false
MEDIA_KEEP_ORIGINAL_PRIVATE=true

# === Cloudflare R2 ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PUBLIC_BUCKET=ueconnect-public-media
R2_PRIVATE_BUCKET=ueconnect-private-media
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_USE_PATH_STYLE_ENDPOINT=false

# === Cloudinary Public Delivery ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true
CLOUDINARY_UPLOAD_FOLDER=ueconnect
CLOUDINARY_DELIVERY_TRANSFORMATIONS=true
CLOUDINARY_SYNC_PUBLIC_VARIANTS=true
CLOUDINARY_FAIL_OPEN=true

# === Firebase Optional / Future-ready ===
FIREBASE_STORAGE_BUCKET=
FIREBASE_CREDENTIALS=

# ==========================================
# 2. GIAI ĐOẠN HOẠT ĐỘNG CHÍNH THỨC (SQL SERVER)
# ==========================================
# Chỉ chuyển đổi sang SQL Server khi máy của bạn đã cài đặt thành công:
# - Microsoft ODBC Driver for SQL Server (ODBC 17/18)
# - Driver PHP (php_sqlsrv và php_pdo_sqlsrv DLLs đã kích hoạt trong php.ini)
# - Đã tạo CSDL 'ue_connect' và tài khoản user tương ứng trên SQL Server.

# DB_CONNECTION=sqlsrv
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_DATABASE=ue_connect
# DB_USERNAME=ue_connect_user
# DB_PASSWORD=YourStrongPassword123

# Tùy chọn cấu hình mã hóa và chứng chỉ tin cậy của SQL Server
# DB_ENCRYPT=false
# DB_TRUST_SERVER_CERTIFICATE=true

# ==========================================
# 3. GIAI ĐOẠN ĐỒNG BỘ DỮ LIỆU ĐỆM HỆ THỐNG (REDIS / DATABASE)
# ==========================================
# Redis is the recommended engine for Cache and Queue for enterprise performance.
# Redis is NOT a replacement for Reverb. Realtime still requires BROADCAST_CONNECTION=reverb.

REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# CACHE_STORE=database
# SESSION_DRIVER=database
# QUEUE_CONNECTION=database

# For production/redis enabled:
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=database (keep session as database since free Redis may not persist data)

# ==========================================
# 4. CẤU HÌNH LARAVEL REVERB REALTIME LOCAL
# ==========================================
# Chỉ đổi BROADCAST_CONNECTION=reverb sau khi đã chạy composer require laravel/reverb và install:broadcasting.
# BROADCAST_CONNECTION=reverb

REVERB_APP_ID=ueconnect-local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret

REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ==========================================
# Microsoft Entra ID (SSO) Configuration
# ==========================================
MICROSOFT_LOGIN_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT_ID=
MICROSOFT_ALLOWED_DOMAINS=student.hcmue.edu.vn,teacher.hcmue.edu.vn


# ==========================================
# 5. CẤU HÌNH DỊCH VỤ MAIL (RESEND / SMTP)
# ==========================================
MAIL_MAILER=resend
RESEND_API_KEY=

# Cấu hình SMTP (Chỉ khi sử dụng SMTP thay vì Resend)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=no-reply@send.ueconnect.io.vn
MAIL_FROM_NAME="${APP_NAME}"

# Dùng log chỉ khi debug local và không cần gửi email thật:
# MAIL_MAILER=log

# === AI Verification ===
# Disabled by default. See docs/setup-tesseract.md for local setup.
AI_VERIFICATION_ENABLED=false
AI_VERIFICATION_PROVIDER=mock
# AI_VERIFICATION_ENABLED=true
# AI_VERIFICATION_PROVIDER=local_hybrid
# AI_OCR_ENGINE=tesseract
# AI_OLLAMA_ENABLED=true

AI_CAPTURE_SESSION_TTL_MINUTES=10
AI_CAPTURE_MAX_ATTEMPTS=5
AI_CAPTURE_MIN_WIDTH=640
AI_CAPTURE_MIN_HEIGHT=360
AI_CAPTURE_JPEG_QUALITY=0.9

AI_OCR_ENGINE=tesseract
TESSERACT_BINARY=tesseract
AI_TESSERACT_LANGS=vie+eng
AI_TESSERACT_PSM=6

AI_PADDLEOCR_SERVICE_URL=
AI_OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT_SECONDS=20

AI_VERIFICATION_LIKELY_MATCH_THRESHOLD=0.85
AI_VERIFICATION_MANUAL_REVIEW_THRESHOLD=0.65
AI_VERIFICATION_SUSPICIOUS_THRESHOLD=0.45

# External fallback: DISABLED by default. Privacy risk — read docs/data-privacy.md first.
AI_EXTERNAL_FALLBACK_ENABLED=false
AI_EXTERNAL_FALLBACK_PROVIDERS=
AI_FALLBACK_SKIP_CONFIDENCE=0.75
AI_ALLOW_EXTERNAL_PROVIDER=false

# Privacy settings: store raw OCR text. Recommended false in production.
AI_STORE_RAW_OCR_TEXT=false

GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT_SECONDS=30

OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=30

# ==========================================
# 6. PRODUCTION DEPLOYMENT (RENDER + AZURE SQL)
# ==========================================
# Below are placeholders for production environment variables on Render.
# Keep these in sync with your .env.production.

# APP_NAME=UEConnect
# APP_ENV=production
# APP_KEY=
# APP_DEBUG=false
# APP_URL=https://ue-connect.onrender.com

# DB_CONNECTION=sqlsrv
# DB_HOST=tcp:<azure-sql-server>.database.windows.net
# DB_PORT=1433
# DB_DATABASE=<database>
# DB_USERNAME=<username>
# DB_PASSWORD=<password>
# DB_ENCRYPT=yes
# DB_TRUST_SERVER_CERTIFICATE=false

# CACHE_STORE=database
# SESSION_DRIVER=database
# QUEUE_CONNECTION=sync
# BROADCAST_CONNECTION=log
# MAIL_MAILER=log

# FILESYSTEM_DISK=r2_public
# MEDIA_STORAGE_STRATEGY=r2_cloudinary
# MEDIA_R2_ENABLED=true
# MEDIA_CLOUDINARY_ENABLED=true
# MEDIA_FIREBASE_ENABLED=false
# MEDIA_DISK=r2_public
# PRIVATE_MEDIA_DISK=r2_private

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_REGION=auto
# R2_PUBLIC_BUCKET=ueconnect-public-media
# R2_PRIVATE_BUCKET=ueconnect-private-media
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=
# R2_USE_PATH_STYLE_ENDPOINT=false

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_SECURE=true

OCR_SPACE_API_KEY=
OCR_SPACE_API_URL=https://api.ocr.space/parse/image

# ==========================================
# HCMUE Chatbot — LLM Provider & Qdrant & Embeddings
# ==========================================
# Supported: gemini, openrouter, ollama
# Reads LLM_PROVIDER first; falls back to AI_LLM_DRIVER (legacy).
LLM_PROVIDER=gemini

# Qdrant configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hcmue_knowledge
QDRANT_VECTOR_SIZE=1024

# Embedding configurations
# Supported: gemini, bge_m3
EMBEDDING_PROVIDER=bge_m3
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=1024

# BGE-M3 Endpoint configuration
BGE_EMBEDDING_URL=https://ntkhoi2005-hcmue-bge-m3-embedding.hf.space
BGE_EMBEDDING_TIMEOUT=120

# Retrieval settings
AI_RETRIEVAL_TOP_K=8
AI_RERANK_TOP_K=5
AI_MIN_RETRIEVAL_SCORE=0.55
AI_TOTAL_CREDITS_TOP_K=20

# ==========================================
# HCMUE Chatbot — Ollama Local LLM
# ==========================================
# OLLAMA_CHAT_MODEL: riêng cho chatbot (không ảnh hưởng OLLAMA_MODEL của AI verification).
# Khuyến nghị cho máy 8GB RAM: gemma4:e2b
# Để cài model: ollama pull gemma4:e2b
# Để test: php artisan hcmue:ollama:test
OLLAMA_CHAT_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1024

# Tự động fallback về cloud nếu Ollama lỗi
OLLAMA_FALLBACK_ENABLED=true
OLLAMA_FALLBACK_PROVIDER=gemini

# Prompt compaction cho máy RAM thấp
OLLAMA_RAG_TOP_K=4
OLLAMA_MAX_CONTEXT_CHARS=12000
OLLAMA_INCLUDE_CHAT_HISTORY=false

# Evaluation thresholds riêng cho Ollama
OLLAMA_EVALUATION_PASS_THRESHOLD=0.70
OLLAMA_CITATION_PASS_THRESHOLD=0.75

VAPID_SUBJECT=https://ueconnect.io.vn/
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=